{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "lutpro"
  ],
  "ios": {
    "iosModuleName": "NitroLutPro"
  },
  "android": {
    "androidNamespace": [
      "lutpro"
    ],
    "androidCxxLibName": "NitroLutPro"
  },
  "autolinking": {
    "LUTProcessor": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridLUTProcessor"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridLUTProcessor"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}